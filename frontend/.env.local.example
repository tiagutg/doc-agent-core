# Copie este arquivo para .env.local e preencha com as URLs reais do seu workflow n8n.
# Enquanto estas variáveis não forem definidas, o hook useDocGeneration roda em
# modo simulado (mock local), permitindo testar toda a UI sem o backend real.

NEXT_PUBLIC_N8N_WEBHOOK_URL=https://seu-n8n.exemplo.com/webhook/gerar-documentacao
NEXT_PUBLIC_N8N_STATUS_URL=https://seu-n8n.exemplo.com/webhook/status-documentacao
